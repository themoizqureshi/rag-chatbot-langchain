# LLM provider — set at least one
# OpenRouter (recommended — no daily quota, aggregates many models): https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Google AI Studio (direct, subject to daily free-tier quota): https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# LangSmith tracing (optional but recommended) — free at https://smith.langchain.com
LANGCHAIN_API_KEY=ls__your-langsmith-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=rag-chatbot-langchain
